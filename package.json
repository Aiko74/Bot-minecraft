{
  "name": "minecraft-bot-assistant",
  "version": "2.0.0",
  "description": "Bot Minecraft autonome pour assister une survie",
  "author": "Aiko74",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node bot.js",
    "bot": "node bot.js",
    "desktop:build": "vite build --config desktop/vite.config.js",
    "desktop": "npm run desktop:build && electron desktop/main.js",
    "desktop:dist": "npm run desktop:build && electron-builder --win nsis zip --x64",
    "v2:exe": "npm run desktop:dist",
    "v1:exe": "npm run desktop:dist",
    "app": "npm run desktop",
    "v1:package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-v1.ps1",
    "server": "node server/index.js",
    "console": "node console-app.js",
    "check": "node --check bot.js"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "minecraft-data": "^3.51.0",
    "mineflayer": "^4.14.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-tool": "^1.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "vec3": "^0.1.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.14"
  },
  "build": {
    "appId": "fr.aiko.minecraft.assistant",
    "productName": "Aiko-Assistant-2077-V2",
    "directories": {
      "output": "release/electron"
    },
    "asar": false,
    "files": [
      "desktop/main.js",
      "desktop/preload.js",
      "desktop/dist/**/*",
      "bot.js",
      "src/**/*",
      "bot-core/**/*",
      "blueprints/**/*",
      "server/**/*",
      "verification/**/*",
      "blueprint-utils.js",
      "console-app.js",
      "farm-config.js",
      "README.md",
      "COMMANDES.md",
      "ARCHITECTURE.md",
      "V1_TEST.md",
      "config.example.json",
      "package.json",
      "!config.json",
      "!bot-memory.json",
      "!server.log",
      "!server.err.log",
      "!data/desktop-settings.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Aiko-Assistant-2077-V2-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aiko Assistant 2077 V2"
    }
  }
}
